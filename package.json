{
  "name": "watervapour",
  "version": "1.1.1",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win"
  },
  "build": {
    "appId": "com.watervapour.app",
    "productName": "WaterVapour",
    "win": {
      "target": "nsis",
      "icon": "Assets/WaterVapourLogo.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true
    },
    "files": [
      "src/**/*",
      "Assets/**/*",
      "package.json"
    ]
  }
}